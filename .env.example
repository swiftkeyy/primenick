APP_ENV=production
APP_NAME=PRIME NICK
APP_BASE_URL=https://bot.example.com
BOT_TOKEN=123456:replace_with_real_token
BOT_WEBHOOK_SECRET=replace_with_32_bytes_random
INTERNAL_HMAC_SECRET=replace_with_64_bytes_random
JWT_ACTIVE_KID=2026-05
JWT_SECRET_2026_05=replace_with_64_bytes_random
DATABASE_URL=postgresql+asyncpg://rarehandle:change_me@postgres:5432/rarehandle
SYNC_DATABASE_URL=postgresql://rarehandle:change_me@postgres:5432/rarehandle
REDIS_URL=redis://:change_me@redis:6379/0
CELERY_BROKER_URL=redis://:change_me@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me@redis:6379/2
REDIS_PASSWORD=change_me
POSTGRES_DB=rarehandle
POSTGRES_USER=rarehandle
POSTGRES_PASSWORD=change_me
TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,127.0.0.1/32
CLOUDFLARE_IP_RANGES=https://api.cloudflare.com/client/v4/ips
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
ROBOKASSA_MERCHANT_LOGIN=prime_nick
ROBOKASSA_PASSWORD1=replace_with_robokassa_password_1
ROBOKASSA_PASSWORD2=replace_with_robokassa_password_2
ROBOKASSA_HASH_ALGORITHM=sha256
ROBOKASSA_IS_TEST=false
ROBOKASSA_PAYMENT_URL=https://auth.robokassa.ru/Merchant/Index.aspx
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace
PYROGRAM_SESSION_NAME=rarehandle_checker
SENTRY_DSN=
LOG_LEVEL=INFO

# Railway optional. If APP_BASE_URL is not set to the public URL, settings.py can derive it from this.
# RAILWAY_PUBLIC_DOMAIN=your-service.up.railway.app
# SERVICE_ROLE=web
